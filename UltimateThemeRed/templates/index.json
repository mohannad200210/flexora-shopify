    "trust_section": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div style=\"background: #f8f8f8; padding: 40px 20px; direction: rtl; text-align: center;\">\n  <h2 style=\"font-family: Cairo, sans-serif; font-size: 2.2rem; color: #1a1a1a; margin-bottom: 30px;\">لماذا تختار فليكسورا؟</h2>\n  <div style=\"display: flex; flex-wrap: wrap; justify-content: center; gap: 30px; max-width: 1000px; margin: 0 auto;\">\n    <div style=\"flex: 1; min-width: 180px; max-width: 220px; text-align: center;\">\n      <div style=\"font-size: 3rem; margin-bottom: 10px;\">🏆</div>\n      <h3 style=\"font-family: Cairo, sans-serif; font-size: 1.6rem; color: #ed122d; margin-bottom: 8px;\">جودة معتمدة</h3>\n      <p style=\"font-family: Cairo, sans-serif; font-size: 1.3rem; color: #555;\">منتجاتنا معتمدة طبياً ومصنوعة من أجود المواد</p>\n    </div>\n    <div style=\"flex: 1; min-width: 180px; max-width: 220px; text-align: center;\">\n      <div style=\"font-size: 3rem; margin-bottom: 10px;\">🚚</div>\n      <h3 style=\"font-family: Cairo, sans-serif; font-size: 1.6rem; color: #ed122d; margin-bottom: 8px;\">شحن سريع</h3>\n      <p style=\"font-family: Cairo, sans-serif; font-size: 1.3rem; color: #555;\">توصيل خلال 2-5 أيام عمل داخل الأردن</p>\n    </div>\n    <div style=\"flex: 1; min-width: 180px; max-width: 220px; text-align: center;\">\n      <div style=\"font-size: 3rem; margin-bottom: 10px;\">💵</div>\n      <h3 style=\"font-family: Cairo, sans-serif; font-size: 1.6rem; color: #ed122d; margin-bottom: 8px;\">دفع عند الاستلام</h3>\n      <p style=\"font-family: Cairo, sans-serif; font-size: 1.3rem; color: #555;\">ادفع نقداً عند استلام طلبك بأمان تام</p>\n    </div>\n    <div style=\"flex: 1; min-width: 180px; max-width: 220px; text-align: center;\">\n      <div style=\"font-size: 3rem; margin-bottom: 10px;\">🔄</div>\n      <h3 style=\"font-family: Cairo, sans-serif; font-size: 1.6rem; color: #ed122d; margin-bottom: 8px;\">ضمان 30 يوم</h3>\n      <p style=\"font-family: Cairo, sans-serif; font-size: 1.3rem; color: #555;\">إذا لم 