    "flexora_bundle": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "\n<div class=\"flexora-bundle-section\" dir=\"rtl\" style=\"background:linear-gradient(180deg,#fff,#f0fafa);padding:48px 16px;font-family:Cairo,sans-serif;border-top:3px solid #0d9488;border-bottom:3px solid #0d9488;\">\n  <style>\n    .flexora-bundle-section * { box-sizing: border-box; }\n    .flexora-bundle-header { text-align: center; max-width: 760px; margin: 0 auto 32px; }\n    .flexora-bundle-header h2 { font-size: 2.4rem; color: #0f172a; margin: 0 0 8px; font-weight: 800; }\n    .flexora-bundle-header h2 em { color: #0d9488; font-style: normal; }\n    .flexora-bundle-header p { font-size: 1.4rem; color: #64748b; margin: 0; }\n    .flexora-bundle-header .pulse-dot { display: inline-block; width: 8px; height: 8px; background: #0d9488; border-radius: 50%; margin-left: 8px; animation: flexora-pulse 1.5s infinite; }\n    @keyframes flexora-pulse {\n      0%, 100% { opacity: 1; transform: scale(1); }\n      50% { opacity: 0.4; transform: scale(1.3); }\n    }\n    .flexora-bundle-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; max-width: 1000px; margin: 0 auto; }\n    @media (max-width: 768px) {\n      .flexora-bundle-grid { grid-template-columns: 1fr; }\n    }\n    .flexora-bundle-card {\n      position: relative;\n      background: #fff;\n      border: 2px solid #e2e8f0;\n      border-radius: 14px;\n      padding: 24px 20px 20px;\n      text-align: center;\n      transition: all 0.25s ease;\n      box-shadow: 0 2px 8px rgba(0,0,0,0.04);\n      display: flex;\n      flex-direction: column;\n    }\n    .flexora-bundle-card:hover { transform: translateY(-4px); box-shadow: 0 10px 25px rgba(13,148,136,0.15); border-color: #0d9488; }\n    .flexora-bundle-card--featured {\n      border: 3px solid #0d9488;\n      background: linear-gradient(180deg, #fff, #ecfdf5);\n      box-shadow: 0 8px 25px rgba(13,148,136,0.2);\n      transform: scale(1.03);\n    }\n    .flexora-bundle-card--featured:hover { transform: scale(1.03) translateY(-4px); }\n    .flexora-bundle-card--featured::before {\n      content: '⭐ الأكثر طلباً';\n      position: absolute;\n      top: -14px;\n      right: 50%;\n      transform: translateX(50%);\n      background: linear-gradient(135deg, #0d9488, #14b8a6);\n      color: #fff;\n      padding: 6px 16px;\n      border-radius: 14px;\n      font-size: 1.2rem;\n      font-weight: 800;\n      box-shadow: 0 4px 12px rgba(13,148,136,0.4);\n      white-space: nowrap;\n    }\n    .flexora-bundle-card__qty { font-size: 3.6rem; font-weight: 800; color: #0f172a; line-height: 1; margin: 8px 0; }\n    .flexora-bundle-card__qty-unit { font-size: 1.3rem; color: #64748b; font-weight: 500; margin-right: 6px; }\n    .flexora-bundle-card__label { font-size: 1.3rem; color: #64748b; margin: 0 0 12px; }\n    .flexora-bundle-card__prices { margin: 12px 0 16px; }\n    .flexora-bundle-card__compare { display: block; color: #94a3b8; text-decoration: line-through; font-size: 1.4rem; margin-bottom: 4px; }\n    .flexora-bundle-card__price { display: block; color: #0d9488; font-size: 2.4rem; font-weight: 800; line-height: 1.1; }\n    .flexora-bundle-card__save {\n      display: inline-block;\n      background: linear-gradient(135deg, #0d9488, #14b8a6);\n      color: #fff;\n      padding: 5px 12px;\n      border-radius: 14px;\n      font-size: 1.2rem;\n      font-weight: 800;\n      margin-top: 8px;\n    }\n    .flexora-bundle-card__save--none {\n      background: #e2e8f0;\n      color: #64748b;\n    }\n    .flexora-bundle-card__per-unit { font-size: 1.15rem; color: #64748b; margin-top: 6px; }\n    .flexora-bundle-card__btn {\n      display: block;\n      width: 100%;\n      margin-top: 16px;\n      padding: 14px 18px;\n      background: #0f172a;\n      color: #fff;\n      border: none;\n      border-radius: 10px;\n      font-size: 1.4rem;\n      font-weight: 800;\n      cursor: pointer;\n      font-family: Cairo, sans-serif;\n      transition: all 0.2s;\n    }\n    .flexora-bundle-card__btn:hover { background: #0d9488; transform: translateY(-1px); }\n    .flexora-bundle-card--featured .flexora-bundle-card__btn { background: #0d9488; }\n    .flexora-bundle-card--featured .flexora-bundle-card__btn:hover { background: #0f766e; }\n    .flexora-bundle-footnote { text-align: center; max-width: 760px; margin: 24px auto 0; font-size: 1.2rem; color: #94a3b8; line-height: 1.7; }\n    .flexora-bundle-footnote strong { color: #475569; }\n  </style>\n\n  <div class=\"flexora-bundle-header\">\n    <h2>اشتر أكثر <em>وفّر أكثر</em> <span class=\"pulse-dot\"></span></h2>\n    <p>اختر العرض المناسب لك — كل ما تشتريه أكثر، زاد توفيرك على الحزام</p>\n  </div>\n\n  <div class=\"flexora-bundle-grid\">\n    <!-- TIER 1: 1 belt, no discount -->\n    <div class=\"flexora-bundle-card\">\n      <div class=\"flexora-bundle-card__qty\"><span class=\"flexora-bundle-card__qty-unit\">×</span>1</div>\n      <p class=\"flexora-bundle-card__label\">حزام واحد</p>\n      <div class=\"flexora-bundle-card__prices\">\n        <span class=\"flexora-bundle-card__compare\" style=\"visibility:hidden;\">JD 19.990</span>\n        <span class=\"flexora-bundle-card__price\">JD 19.990</span>\n        <span class=\"flexora-bundle-card__save flexora-bundle-card__save--none\">بدون خصم</span>\n      </div>\n      <p class=\"flexora-bundle-card__per-unit\">JD 19.990 / للحزام</p>\n      <form method=\"post\" action=\"/cart/add\" id=\"flexora-bundle-form-1\" style=\"margin:0;\">\n        <input type=\"hidden\" name=\"id\" value=\"{{ product.selected_or_first_available_variant.id }}\">\n        <input type=\"hidden\" name=\"quantity\" value=\"1\">\n        <input type=\"hidden\" name=\"properties[_flexora_bundle_tier]\" value=\"tier1-1x\">\n        <input type=\"hidden\" name=\"properties[_flexora_bundle_qty]\" value=\"1\">\n        <button type=\"submit\" name=\"add\" class=\"flexora-bundle-card__btn\" onclick=\"return flexoraBundleAdd(this.form, 1);\">أضف 1 للسلة</button>\n      </form>\n    </div>\n\n    <!-- TIER 2: 2 belts, 12% off — FEATURED -->\n    <div class=\"flexora-bundle-card flexora-bundle-card--featured\">\n      <div class=\"flexora-bundle-card__qty\"><span class=\"flexora-bundle-card__qty-unit\">×</span>2</div>\n      <p class=\"flexora-bundle-card__label\">حزامان (الأكثر طلباً)</p>\n      <div class=\"flexora-bundle-card__prices\">\n        <span class=\"flexora-bundle-card__compare\">JD 39.980</span>\n        <span class=\"flexora-bundle-card__price\">JD 35.182</span>\n        <span class=\"flexora-bundle-card__save\">وفّر 4.798 JD · خصم 12٪</span>\n      </div>\n      <p class=\"flexora-bundle-card__per-unit\">JD 17.591 / للحزام</p>\n      <form method=\"post\" action=\"/cart/add\" id=\"flexora-bundle-form-2\" style=\"margin:0;\">\n        <input type=\"hidden\" name=\"id\" value=\"{{ product.selected_or_first_available_variant.id }}\">\n        <input type=\"hidden\" name=\"quantity\" value=\"2\">\n        <input type=\"hidden\" name=\"properties[_flexora_bundle_tier]\" value=\"tier2-2x\">\n        <input type=\"hidden\" name=\"properties[_flexora_bundle_qty]\" value=\"2\">\n        <input type=\"hidden\" name=\"properties[_flexora_bundle_discount_pct]\" value=\"12\">\n        <button type=\"submit\" name=\"add\" class=\"flexora-bundle-card__btn\" onclick=\"return flexoraBundleAdd(this.form, 2);\">أضف 2 للسلة</button>\n      </form>\n    </div>\n\n    <!-- TIER 3: 3 belts, 22% off -->\n    <div class=\"flexora-bundle-card\">\n      <div class=\"flexora-bundle-card__qty\"><span class=\"flexora-bundle-card__qty-unit\">×</span>3</div>\n      <p class=\"flexora-bundle-card__label\">ثلاثة أحزمة (أفضل قيمة)</p>\n      <div class=\"flexora-bundle-card__prices\">\n        <span class=\"flexora-bundle-card__compare\">JD 59.970</span>\n        <span class=\"flexora-bundle-card__price\">JD 46.777</span>\n        <span class=\"flexora-bundle-card__save\">وفّر 13.193 JD · خصم 22٪</span>\n      </div>\n      <p class=\"flexora-bundle-card__per-unit\">JD 15.592 / للحزام</p>\n      <form method=\"post\" action=\"/cart/add\" id=\"flexora-bundle-form-3\" style=\"margin:0;\">\n        <input type=\"hidden\" name=\"id\" value=\"{{ product.selected_or_first_available_variant.id }}\">\n        <input type=\"hidden\" name=\"quantity\" value=\"3\">\n        <input type=\"hidden\" name=\"properties[_flexora_bundle_tier]\" value=\"tier3-3x\">\n        <input type=\"hidden\" name=\"properties[_flexora_bundle_qty]\" value=\"3\">\n        <input type=\"hidden\" name=\"properties[_flexora_bundle_discount_pct]\" value=\"22\">\n        <button type=\"submit\" name=\"add\" class=\"flexora-bundle-card__btn\" onclick=\"return flexoraBundleAdd(this.form, 3);\">أضف 3 للسلة</button>\n      </form>\n    </div>\n  </div>\n\n  <p class=\"flexora-bundle-footnote\">\n    <strong>ملاحظة للتجار:</strong> الخصومات أعلاه بصرية — لتطبيق الخصم الفعلي في السلة، أنشئ خصماً تلقائياً في Shopify Admin (Settings → Discounts → Automatic) بشروط: <em>Buy 2 of [hizam-alzahr-altbi-flexora] get 12% off</em> و <em>Buy 3 of [hizam-alzahr-altbi-flexora] get 22% off</em>. الخاصية <code>_flexora_bundle_tier</code> على عناصر السلة تسمح لك بتطبيق منطق خصم مخصص عبر Shopify Function.\n  </p>\n</div>\n\n<script>\nfunction flexoraBundleAdd(form, qty) {\n  // Use Shopify's AJAX cart API so the add happens without a page reload.\n  // This is the same mechanism the theme's main product form uses.\n  event.preventDefault();\n  var btn = form.querySelector('button[type=submit]');\n  var originalText = btn.textContent;\n  btn.disabled = true;\n  btn.textContent = 'جاري الإضافة...';\n  var formData = new FormData(form);\n  fetch('/cart/add.js', {\n    method: 'POST',\n    body: formData,\n    headers: { 'Accept': 'application/javascript' }\n  })\n  .then(function(r) { return r.json(); })\n  .then(function(line) {\n    btn.textContent = '✓ تمت الإضافة';\n    btn.style.background = '#10b981';\n    // Notify the cart drawer / cart icon to refresh\n    document.documentElement.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));\n    document.dispatchEvent(new CustomEvent('ajaxProduct:added', { detail: { line: line, quantity: qty } }));\n    setTimeout(function() { btn.textContent = originalText; btn.style.background = ''; btn.disabled = false; }, 1800);\n  })\n  .catch(function(e) {\n    btn.textContent = 'حدث خطأ — حاول مجدداً';\n    btn.disabled = false;\n    console.error('flexoraBundleAdd error:', e);\n  });\n  return false;\n}\n</script>\n",
